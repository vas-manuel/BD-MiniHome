<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Crear tabla plans -->
    <changeSet id="005-1-create-plans-table" author="saas">
        <createTable tableName="plans">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="max_users" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="max_bill_accounts" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="max_history_months" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="price_monthly" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Agregar columnas de suscripción a households -->
    <changeSet id="005-2-add-plan-to-households" author="saas">
        <addColumn tableName="households">
            <column name="plan_id" type="UUID"/>
            <column name="subscription_status" type="VARCHAR(20)" defaultValue="TRIAL"/>
            <column name="subscription_ends_at" type="TIMESTAMP"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
