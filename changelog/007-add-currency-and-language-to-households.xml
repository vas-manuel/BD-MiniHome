<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Agregar moneda e idioma a households -->
    <changeSet id="007-1-add-currency-language-to-households" author="saas">
        <addColumn tableName="households">
            <column name="currency" type="VARCHAR(10)" defaultValue="CLP">
                <constraints nullable="false"/>
            </column>
            <column name="language" type="VARCHAR(10)" defaultValue="es">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
